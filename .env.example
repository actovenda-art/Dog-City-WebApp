# Variáveis de ambiente para desenvolvimento e deploy
# Copie este arquivo para .env.local e preencha com seus valores

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
VITE_SITE_URL=https://dogcitybrasil.com.br
VITE_SUPABASE_PUBLIC_BUCKET=public-assets
VITE_SUPABASE_PRIVATE_BUCKET=private-files
VITE_EMAIL_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/send-email

# Secrets for the Supabase Edge Function `send-email`
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Dog City Brasil <convites@seudominio.com>
EMAIL_REPLY_TO=suporte@seudominio.com

# API (opcional)
VITE_API_URL=https://api.example.com
